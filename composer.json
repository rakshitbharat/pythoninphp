{
    "name": "rakshitbharat/pythoninphp",
    "description": "Execute Python scripts seamlessly from your Laravel PHP applications.",
    "keywords": [
        "laravel",
        "php",
        "python",
        "process"
    ],
    "homepage": "https://github.com/rakshitbharat/pythoninphp",
    "license": "MIT",
    "type": "library",
    "authors": [
        {
            "name": "Rakshit Patel",
            "email": "rakshitbharatproject@gmail.com",
            "role": "Developer"
        }
    ],
    "require": {
        "php": "^8.2",
        "illuminate/support": "^10.0 || ^11.0",
        "symfony/process": "^6.0 || ^7.0"
    },
    "require-dev": {
        "orchestra/testbench": "^8.0 || ^9.0",
        "phpunit/phpunit": "^10.0 || ^11.0"
    },
    "autoload": {
        "psr-4": {
            "Rakshitbharat\\Pythoninphp\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "Rakshitbharat\\Pythoninphp\\Tests\\": "tests/"
        }
    },
    "extra": {
        "laravel": {
            "providers": [
                "Rakshitbharat\\Pythoninphp\\PythonServiceProvider"
            ],
            "aliases": {
                "Python": "Rakshitbharat\\Pythoninphp\\Facades\\Python"
            }
        }
    },
    "scripts": {
        "test": "vendor/bin/phpunit"
    },
    "config": {
        "sort-packages": true,
        "policy.advisories.block": false,
        "policy": {
            "advisories": {
                "block": false
            }
        }
    }
}
